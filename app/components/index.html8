<!DOCTYPE html>
<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Roomie Guest Profile</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,typography,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#1A44D6",
                        gold: "#C6A653",
                        "background-light": "#FAFAFA",
                        "background-dark": "#121212",
                        "surface-light": "#FFFFFF",
                        "surface-dark": "#1E1E1E",
                        "text-light": "#1F2937",
                        "text-dark": "#E5E7EB",
                        "muted-light": "#6B7280",
                        "muted-dark": "#9CA3AF",
                    },
                    fontFamily: {
                        display: ["DM Sans", "sans-serif"],
                    },
                    borderRadius: {
                        DEFAULT: "0.5rem",
                        'xl': '1rem',
                        '2xl': '1.5rem',
                    },
                    boxShadow: {
                        'float': '0 10px 40px -10px rgba(0,0,0,0.15)',
                    }
                },
            },
        };
    </script>
<style type="text/tailwindcss">
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        .glass-nav {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        .dark .glass-nav {
            background: rgba(30, 30, 30, 0.85);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        body {
            min-height: max(884px, 100dvh);
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 200, 'GRAD' 0, 'opsz' 48;
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background-light dark:bg-background-dark font-display text-text-light dark:text-text-dark transition-colors duration-200 antialiased pb-32">
<div class="h-12 w-full"></div>
<header class="flex flex-col items-center justify-center pt-4 pb-6 px-6">
<div class="relative mb-4">
<div class="w-24 h-24 rounded-full p-1 bg-white dark:bg-surface-dark shadow-sm">
<img alt="Profile avatar of Alexander Sterling" class="w-full h-full rounded-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAC1VurAfOFYdqGT4-ma_gAxnLXGUoo84h6vweANbbfs-3DhEJC70W75gVHgd3BBHmBQ1Q1Nlh5sdVBWLobb4ukoyU4vORw4vF6CFkFNzjzzh1CB-t1elSMchLqoGvkwFhaglfo00Mo-5S772DPN94KGLKv83kIuBfzb4EpNSTHOKxGRI9dC4O-pzAZp_MRK488dujFxb9Ob4aCMtaY8hgO3F_x-XfNhHd9VoyBysEP6Ovvc0Bb1sba-FSf2T9RWp1hjPtTLpk1VrPd"/>
</div>
<button class="absolute bottom-0 right-0 bg-primary text-white p-2 rounded-full shadow-lg hover:bg-blue-700 transition flex items-center justify-center w-8 h-8">
<span class="material-icons-round text-sm">edit</span>
</button>
</div>
<h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">Alexander Sterling</h1>
<div class="flex items-center gap-1 text-primary font-medium">
<span class="material-icons-round text-sm">verified</span>
<span class="text-sm">Platinum Member</span>
</div>
</header>
<main class="px-5 space-y-8">
<section class="bg-surface-light dark:bg-surface-dark rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-800">
<div class="flex justify-between items-start mb-2">
<h2 class="text-gold text-xs font-bold tracking-wider uppercase">Loyalty Dashboard</h2>
<div class="flex flex-col gap-3 -mt-1 -mr-1">
<button class="text-gold/60 flex items-center justify-center">
<span class="material-symbols-outlined text-[32px] leading-none">info</span>
</button>
<button class="text-gold/60 flex items-center justify-center">
<span class="material-symbols-outlined text-[32px] leading-none">history</span>
</button>
</div>
</div>
<div class="mb-6">
<div class="text-4xl font-bold text-gray-900 dark:text-white">12,450</div>
<div class="text-xs text-muted-light dark:text-muted-dark uppercase tracking-wide font-medium mt-1">Points Balance</div>
</div>
<div class="w-full bg-gray-100 dark:bg-gray-700 h-2 rounded-full overflow-hidden mb-2 relative">
<div class="bg-gradient-to-r from-yellow-500 to-gold h-full rounded-full" style="width: 75%;"></div>
</div>
<div class="flex justify-between text-xs font-medium text-gray-900 dark:text-white">
<span>Platinum Status</span>
<span class="text-muted-light dark:text-muted-dark">Next tier <span class="text-gray-900 dark:text-white ml-1">Diamond</span></span>
</div>
</section>
<section>
<div class="flex justify-between items-center mb-4 px-1">
<h3 class="text-xs font-bold text-muted-light dark:text-muted-dark uppercase tracking-wider">Personal Information</h3>
<button class="text-primary text-sm font-semibold hover:text-blue-700">Edit</button>
</div>
<div class="bg-surface-light dark:bg-surface-dark rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 divide-y divide-gray-100 dark:divide-gray-800">
<div class="p-4 flex items-center justify-between">
<div>
<p class="text-xs text-muted-light dark:text-muted-dark mb-1">Email Address</p>
<p class="text-sm font-medium text-gray-900 dark:text-white">a.sterling@private.com</p>
</div>
<span class="material-icons-round text-muted-light dark:text-muted-dark opacity-50">mail_outline</span>
</div>
<div class="p-4 flex items-center justify-between">
<div>
<p class="text-xs text-muted-light dark:text-muted-dark mb-1">Phone Number</p>
<p class="text-sm font-medium text-gray-900 dark:text-white">+1 (555) 924-1100</p>
</div>
<span class="material-icons-round text-muted-light dark:text-muted-dark opacity-50">smartphone</span>
</div>
</div>
</section>
<section>
<h3 class="text-xs font-bold text-muted-light dark:text-muted-dark uppercase tracking-wider mb-4 px-1">Preferences</h3>
<div class="bg-surface-light dark:bg-surface-dark rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 p-4 flex items-center justify-between">
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-full bg-gray-50 dark:bg-gray-800 flex items-center justify-center text-gray-900 dark:text-white">
<span class="material-icons-round text-xl">wb_sunny</span>
</div>
<span class="font-medium text-gray-900 dark:text-white">Appearance</span>
</div>
<button class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none bg-gray-200 dark:bg-gray-600" onclick="document.documentElement.classList.toggle('dark')">
<span class="sr-only">Use setting</span>
<span aria-hidden="true" class="translate-x-0 dark:translate-x-5 pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out"></span>
</button>
</div>
</section>
<section>
<div class="flex justify-between items-center mb-4 px-1">
<h3 class="text-xs font-bold text-muted-light dark:text-muted-dark uppercase tracking-wider">Stay History</h3>
<button class="text-primary text-sm font-semibold hover:text-blue-700">See All</button>
</div>
<div class="flex overflow-x-auto space-x-4 no-scrollbar pb-4 -mx-5 px-5">
<div class="flex-shrink-0 w-72 bg-surface-light dark:bg-surface-dark rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 overflow-hidden">
<div class="h-40 w-full relative">
<img alt="The Grand Royal hotel facade" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD_Mmr9d3_ZLx-6EAAzxLGpGb7h5uAHDTnchMMat6JHT_jrTceQwzwHpLt3K2Ntdd9OYXhJVAkDGAc-qHvVjgQJW-r6zfjnz69mFfIasj6O6ETUQvqLzuqc1q-qqHV_a0wgsVUpTdDOoCAKQJ8ZOT4BsYDzWusHhPYMNpHXghpLPK2OUN21wChTezWeuQ2P2swff8QdsapQhz6-ExdLSROK9fcvzAVbtLP5pkhOyiOfJhKeCJPu1csUEwcJhDuAkdQtI0FyRIWfB-Vy"/>
<div class="absolute top-3 right-3 bg-white dark:bg-gray-900 px-2 py-1 rounded text-[10px] font-bold tracking-wide uppercase text-gray-900 dark:text-white">Completed</div>
</div>
<div class="p-4">
<h4 class="font-bold text-gray-900 dark:text-white text-lg mb-1">The Grand Royal, London</h4>
<div class="flex items-center justify-between mb-4">
<p class="text-xs text-muted-light dark:text-muted-dark">May 12 - May 16, 2024</p>
<div class="flex items-center gap-1 text-gold">
<span class="material-icons-round text-[10px]">auto_awesome</span>
<span class="text-[10px] font-bold tracking-wide">2,972 points earned</span>
</div>
</div>
<button class="w-full py-3 bg-blue-50 dark:bg-blue-900/30 text-primary text-sm font-bold rounded-xl hover:bg-blue-100 dark:hover:bg-blue-900/50 transition">
                        REBOOK STAY
                    </button>
</div>
</div>
<div class="flex-shrink-0 w-72 bg-surface-light dark:bg-surface-dark rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 overflow-hidden">
<div class="h-40 w-full relative">
<img alt="Azure Sanctuary resort pool" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDD99OObCgyOyFFH97ftQNzKTtex-qebI3OSAPs4lKpJAp_1tfz97V7d5CtQ8XTs1C7I0mysu6_jjseMhly7koeieQn4sXIYHjGGxVBWmmnLQlfKtTifAz1wNH435By095Hl4u3GqiFiJWC3im64qEbQRbwy1wLeWruB0tdND7ezu2tFTogy9lZu9gDafpOQceFzT7qzlok4HO9_lmgKHgNrwYbmobl4QwueffyyhXLteAxIBNuJcj9okLdxkcI7xbBCf18tPw1yEcL"/>
<div class="absolute top-3 right-3 bg-white dark:bg-gray-900 px-2 py-1 rounded text-[10px] font-bold tracking-wide uppercase text-gray-900 dark:text-white">Completed</div>
</div>
<div class="p-4">
<h4 class="font-bold text-gray-900 dark:text-white text-lg mb-1">Azure Sanctuary, Maldives</h4>
<div class="flex items-center justify-between mb-4">
<p class="text-xs text-muted-light dark:text-muted-dark">Feb 02 - Feb 08, 2024</p>
<div class="flex items-center gap-1 text-gold">
<span class="material-icons-round text-[10px]">auto_awesome</span>
<span class="text-[10px] font-bold tracking-wide">4,120 points earned</span>
</div>
</div>
<button class="w-full py-3 bg-blue-50 dark:bg-blue-900/30 text-primary text-sm font-bold rounded-xl hover:bg-blue-100 dark:hover:bg-blue-900/50 transition">
                        REBOOK STAY
                    </button>
</div>
</div>
</div>
</section>
<section>
<h3 class="text-xs font-bold text-muted-light dark:text-muted-dark uppercase tracking-wider mb-4 px-1">Notifications</h3>
<div class="bg-surface-light dark:bg-surface-dark rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 divide-y divide-gray-100 dark:divide-gray-800">
<div class="p-4 flex items-center justify-between">
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-full bg-blue-50 dark:bg-blue-900/30 flex items-center justify-center text-primary">
<span class="material-icons-round text-xl">notifications</span>
</div>
<span class="font-medium text-gray-900 dark:text-white">Stay Updates</span>
</div>
<button class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none bg-primary">
<span aria-hidden="true" class="translate-x-5 pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out"></span>
</button>
</div>
<div class="p-4 flex items-center justify-between">
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-full bg-blue-50 dark:bg-blue-900/30 flex items-center justify-center text-primary">
<span class="material-icons-round text-xl">local_offer</span>
</div>
<span class="font-medium text-gray-900 dark:text-white">Exclusive Offers</span>
</div>
<button class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none bg-gray-200 dark:bg-gray-600">
<span aria-hidden="true" class="translate-x-0 pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out"></span>
</button>
</div>
</div>
</section>
<div class="pt-4 pb-8 flex flex-col items-center">
<button class="text-red-500 font-bold tracking-wide text-sm mb-4 hover:text-red-600">LOG OUT</button>
<p class="text-[10px] text-muted-light dark:text-muted-dark uppercase tracking-widest font-medium">Roomie Guest v4.2.0</p>
</div>
</main>
<div class="fixed bottom-8 left-0 right-0 z-50 flex justify-center px-4 pointer-events-none">
<nav class="glass-nav rounded-full px-8 py-3 shadow-float pointer-events-auto flex items-center justify-between w-full max-w-[340px]">
<a class="flex flex-col items-center gap-1 group" href="#">
<span class="material-icons-round text-muted-light dark:text-muted-dark group-hover:text-primary transition-colors text-xl">home</span>
<span class="text-[10px] font-medium text-muted-light dark:text-muted-dark group-hover:text-primary transition-colors">Home</span>
</a>
<a class="flex flex-col items-center gap-1 group" href="#">
<span class="material-icons-round text-muted-light dark:text-muted-dark group-hover:text-primary transition-colors text-xl">bed</span>
<span class="text-[10px] font-medium text-muted-light dark:text-muted-dark group-hover:text-primary transition-colors">Services</span>
</a>
<a class="flex flex-col items-center gap-1 group" href="#">
<span class="material-icons-round text-muted-light dark:text-muted-dark group-hover:text-primary transition-colors text-xl">receipt_long</span>
<span class="text-[10px] font-medium text-muted-light dark:text-muted-dark group-hover:text-primary transition-colors">Orders</span>
</a>
<a class="flex flex-col items-center gap-1" href="#">
<span class="material-icons-round text-gold text-xl">person</span>
<span class="text-[10px] font-bold text-gold">Account</span>
</a>
</nav>
</div>

</body></html>