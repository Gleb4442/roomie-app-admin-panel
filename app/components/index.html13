<!DOCTYPE html>
<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Housekeeping Items Selected - Roomie Guest</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#1052d5",
                        "background-light": "#f6f6f8",
                        "background-dark": "#101622",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "1rem",
                        "lg": "2rem",
                        "xl": "3rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
<style type="text/tailwindcss">
        @layer components {
            .liquid-glass {
                background: rgba(255, 255, 255, 0.7);
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                border: 1px solid rgba(255, 255, 255, 0.3);
                box-shadow: 0 8px 32px 0 rgba(16, 82, 213, 0.1);
            }
            .ai-pulse {
                box-shadow: 0 0 0 0 rgba(16, 82, 213, 0.4);
                animation: pulse 2s infinite;
            }
            @keyframes pulse {
                0% { box-shadow: 0 0 0 0 rgba(16, 82, 213, 0.4); }
                70% { box-shadow: 0 0 0 15px rgba(16, 82, 213, 0); }
                100% { box-shadow: 0 0 0 0 rgba(16, 82, 213, 0); }
            }
            .custom-scrollbar::-webkit-scrollbar {
                display: none;
            }.hidden-state {
                display: none;
            }
        }
    </style>
<style>
        body {
            min-height: max(884px, 100dvh);
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 antialiased">
<div class="relative flex h-screen max-w-md mx-auto flex-col bg-white dark:bg-slate-900 overflow-hidden shadow-2xl">
<header class="flex items-center justify-between px-6 pt-12 pb-4">
<button class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-slate-100">
<span class="material-symbols-outlined">arrow_back_ios_new</span>
</button>
<h1 class="text-xl font-bold tracking-tight text-center">Housekeeping</h1>
<div class="w-10"></div>
</header>
<main class="flex-1 overflow-y-auto custom-scrollbar px-6 pb-48">
<div class="mt-4 mb-6">
<h2 class="text-2xl font-bold text-slate-900 dark:text-white">Premium Services</h2>
<p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Select items for your room</p>
</div>
<div class="space-y-3">
<div class="flex items-center justify-between p-4 bg-white dark:bg-slate-800 border-2 border-primary/20 dark:border-primary/40 rounded-2xl shadow-md">
<div class="flex items-center gap-4">
<div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
<span class="material-symbols-outlined">layers</span>
</div>
<div>
<p class="font-semibold text-slate-900 dark:text-white">Fresh Towels</p>
<p class="text-xs text-slate-400">Set of 2 Cotton Towels</p>
</div>
</div>
<div class="flex items-center gap-3 text-primary">
<span class="material-symbols-outlined font-bold text-3xl">check_circle</span>
</div>
</div>
<div class="flex items-center justify-between p-4 bg-white dark:bg-slate-800 border border-slate-100 dark:border-slate-700 rounded-2xl shadow-sm">
<div class="flex items-center gap-4">
<div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
<span class="material-symbols-outlined">auto_fix_high</span>
</div>
<div>
<p class="font-semibold text-slate-900 dark:text-white">Room Cleaning</p>
<p class="text-xs text-slate-400">Complete deep clean</p>
</div>
</div>
<button class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 active:scale-95 transition-transform">
<span class="material-symbols-outlined">add</span>
</button>
</div>
<div class="flex items-center justify-between p-4 bg-white dark:bg-slate-800 border-2 border-primary/20 dark:border-primary/40 rounded-2xl shadow-md">
<div class="flex items-center gap-4">
<div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
<span class="material-symbols-outlined">bedroom_parent</span>
</div>
<div>
<p class="font-semibold text-slate-900 dark:text-white">Extra Pillows</p>
<p class="text-xs text-slate-400">Hypoallergenic memory foam</p>
</div>
</div>
<div class="flex items-center gap-3 text-primary">
<span class="material-symbols-outlined font-bold text-3xl">check_circle</span>
</div>
</div>
<div class="flex items-center justify-between p-4 bg-white dark:bg-slate-800 border border-slate-100 dark:border-slate-700 rounded-2xl shadow-sm">
<div class="flex items-center gap-4">
<div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
<span class="material-symbols-outlined">sanitizer</span>
</div>
<div>
<p class="font-semibold text-slate-900 dark:text-white">Toiletries Refill</p>
<p class="text-xs text-slate-400">Luxury soaps &amp; shampoos</p>
</div>
</div>
<button class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 active:scale-95 transition-transform">
<span class="material-symbols-outlined">add</span>
</button>
</div>
<div class="flex items-center justify-between p-4 bg-white dark:bg-slate-800 border border-slate-100 dark:border-slate-700 rounded-2xl shadow-sm">
<div class="flex items-center gap-4">
<div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
<span class="material-symbols-outlined">checkroom</span>
</div>
<div>
<p class="font-semibold text-slate-900 dark:text-white">Laundry Service</p>
<p class="text-xs text-slate-400">Same day wash &amp; fold</p>
</div>
</div>
<button class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 active:scale-95 transition-transform">
<span class="material-symbols-outlined">add</span>
</button>
</div>
</div>
<div class="mt-10 mb-4 flex items-center gap-2">
<span class="material-symbols-outlined text-primary text-xl">psychology_alt</span>
<h3 class="text-lg font-bold text-slate-900 dark:text-white">Ask AI Agent</h3>
</div>
<div class="relative w-full p-1 rounded-full ai-pulse mb-8">
<div class="liquid-glass rounded-full flex items-center px-6 py-4 border border-white/50">
<input class="w-full bg-transparent border-none focus:ring-0 text-slate-800 dark:text-white placeholder:text-slate-400 placeholder:font-medium font-medium" placeholder="Tell our AI what you need..." type="text"/>
<button class="ml-2 flex items-center justify-center h-10 w-10 rounded-full bg-primary text-white">
<span class="material-symbols-outlined">send</span>
</button>
</div>
<p class="mt-4 px-4 text-xs text-center text-slate-400 italic">Try: "I need 5 more hangers and a bottle of sparkling water"</p>
</div>
</main>
<div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-white via-white/95 to-transparent dark:from-slate-900 dark:via-slate-900/95 dark:to-transparent pb-10 pt-6 px-6 z-20">
<div id="action-buttons-container">
<div class="w-full bg-primary text-white p-2 rounded-2xl shadow-xl shadow-primary/30 mb-6 flex items-center justify-between">
<div class="pl-6 flex items-center">
<span class="text-lg font-bold">Place Order</span>
</div>
<div class="flex items-center gap-2 pr-2">
<button class="h-12 w-12 flex items-center justify-center rounded-xl bg-white/10 hover:bg-white/20 active:bg-white/30 transition-colors border border-white/10">
<span class="material-symbols-outlined text-white/90">close</span>
</button>
<button class="h-12 w-12 flex items-center justify-center rounded-xl bg-white text-primary shadow-lg active:scale-95 transition-transform" onclick="document.getElementById('action-buttons-container').style.display='none'; document.getElementById('success-message-container').classList.remove('hidden')">
<span class="material-symbols-outlined font-bold">check</span>
</button>
</div>
</div>
</div>
<div class="hidden w-full bg-green-500 text-white py-4 px-6 rounded-2xl shadow-xl shadow-green-500/30 mb-6 flex items-center justify-center gap-3 animate-fade-in" id="success-message-container">
<div class="bg-white/20 rounded-full p-1">
<span class="material-symbols-outlined text-2xl font-bold block">check</span>
</div>
<span class="text-lg font-bold">Order Successfully Placed</span>
</div>
<nav class="flex h-16 w-full items-center justify-around rounded-full bg-white/90 dark:bg-slate-800/90 backdrop-blur-lg shadow-2xl border border-slate-200/50 dark:border-slate-700/50 px-4">
<a class="flex flex-col items-center justify-center gap-1 text-slate-400 dark:text-slate-500" href="#">
<span class="material-symbols-outlined">home</span>
<span class="text-[10px] font-bold">HOME</span>
</a>
<a class="flex flex-col items-center justify-center gap-1 text-primary" href="#">
<span class="material-symbols-outlined text-fill">room_service</span>
<span class="text-[10px] font-bold">SERVICES</span>
</a>
<a class="flex flex-col items-center justify-center gap-1 text-slate-400 dark:text-slate-500" href="#">
<span class="material-symbols-outlined">receipt_long</span>
<span class="text-[10px] font-bold">ORDERS</span>
</a>
<a class="flex flex-col items-center justify-center gap-1 text-slate-400 dark:text-slate-500" href="#">
<span class="material-symbols-outlined">account_circle</span>
<span class="text-[10px] font-bold">PROFILE</span>
</a>
</nav>
</div>
<div class="absolute bottom-1 left-1/2 -translate-x-1/2 w-32 h-1.5 bg-slate-200 dark:bg-slate-700 rounded-full z-30"></div>
</div>
</body></html>