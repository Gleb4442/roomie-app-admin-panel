<!DOCTYPE html>
<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>My Orders &amp; Requests - Roomie Guest</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#1152d4",
                        "background-light": "#f6f6f8",
                        "background-dark": "#101622",
                    },
                    fontFamily: {
                        "display": ["Inter"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
<style type="text/tailwindcss">
        body {
            min-height: max(884px, 100dvh);
        }
        .glass-nav {
            @apply bg-white/70 dark:bg-slate-900/70 backdrop-blur-md border border-white/20 dark:border-slate-800/50 shadow-[0_8px_32px_0_rgba(0,0,0,0.1)];
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 antialiased">
<div class="max-w-[430px] mx-auto min-h-screen bg-background-light dark:bg-background-dark relative pb-32 overflow-hidden shadow-2xl">
<div class="h-12 bg-white dark:bg-slate-900"></div>
<header class="bg-white dark:bg-slate-900 px-6 pt-4 pb-6 sticky top-0 z-10">
<div class="flex items-center justify-between mb-6">
<div class="w-10"></div>
<div class="text-xs font-semibold tracking-widest uppercase text-slate-400 dark:text-slate-500">Room 402</div>
<button class="w-10 h-10 flex items-center justify-end text-primary">
<span class="material-icons">help_outline</span>
</button>
</div>
<h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white">Orders &amp; Requests</h1>
</header>
<div class="px-6 py-4">
<div class="bg-slate-200/50 dark:bg-slate-800 p-1 rounded-xl flex">
<button class="flex-1 py-2 text-sm font-semibold rounded-lg bg-white dark:bg-slate-700 shadow-sm text-slate-900 dark:text-white">
                    Active (2)
                </button>
<button class="flex-1 py-2 text-sm font-medium text-slate-500 dark:text-slate-400">
                    Past
                </button>
</div>
</div>
<main class="px-6 space-y-6">
<section>
<div class="flex items-center justify-between mb-4">
<h2 class="text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Current Services</h2>
</div>
<div class="space-y-4">
<div class="bg-white dark:bg-slate-900 rounded-xl p-5 shadow-sm border border-slate-100 dark:border-slate-800">
<div class="flex justify-between items-start mb-4">
<div class="flex gap-4">
<div class="w-12 h-12 bg-primary/10 dark:bg-primary/20 rounded-lg flex items-center justify-center text-primary">
<span class="material-icons">lunch_dining</span>
</div>
<div>
<h3 class="font-semibold text-slate-900 dark:text-white">Wagyu Beef Burger</h3>
<p class="text-xs text-slate-500 dark:text-slate-400">Ordered at 18:45 • Room Service</p>
</div>
</div>
<span class="px-3 py-1 bg-amber-100 dark:bg-amber-900/30 text-amber-600 dark:text-amber-400 text-[10px] font-bold uppercase tracking-wide rounded-full">
                                Cooking
                            </span>
</div>
<div class="space-y-2">
<div class="flex justify-between text-[11px] font-medium text-slate-400 dark:text-slate-500">
<span>Estimated delivery: 15-20 min</span>
<span>65%</span>
</div>
<div class="w-full bg-slate-100 dark:bg-slate-800 h-1.5 rounded-full overflow-hidden">
<div class="bg-primary h-full w-[65%] rounded-full"></div>
</div>
</div>
<div class="flex justify-end mt-3">
<button class="text-xs font-semibold text-primary uppercase tracking-wide">Details</button>
</div>
</div>
<div class="bg-white dark:bg-slate-900 rounded-xl p-5 shadow-sm border border-slate-100 dark:border-slate-800">
<div class="flex justify-between items-start">
<div class="flex gap-4">
<div class="w-12 h-12 bg-primary/10 dark:bg-primary/20 rounded-lg flex items-center justify-center text-primary">
<span class="material-icons">layers</span>
</div>
<div>
<h3 class="font-semibold text-slate-900 dark:text-white">Extra Towels (x2)</h3>
<p class="text-xs text-slate-500 dark:text-slate-400">Ordered at 19:12 • Housekeeping</p>
</div>
</div>
<span class="px-3 py-1 bg-blue-100 dark:bg-blue-900/30 text-primary dark:text-blue-400 text-[10px] font-bold uppercase tracking-wide rounded-full whitespace-nowrap">
                                In Transit
                            </span>
</div>
<div class="mt-4 pt-4 border-t border-slate-50 dark:border-slate-800 flex items-center gap-2">
<span class="material-icons text-primary text-sm">schedule</span>
<p class="text-xs text-slate-600 dark:text-slate-400">Arriving in approx. <span class="font-bold">5 mins</span></p>
</div>
</div>
</div>
</section>
<section class="pt-4">
<div class="flex items-center justify-between mb-4">
<h2 class="text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Recently Completed</h2>
</div>
<div class="bg-white/60 dark:bg-slate-900/40 rounded-xl p-5 border border-dashed border-slate-200 dark:border-slate-800">
<div class="flex justify-between items-center opacity-70">
<div class="flex gap-4">
<div class="w-12 h-12 bg-slate-100 dark:bg-slate-800 rounded-lg flex items-center justify-center text-slate-400">
<span class="material-icons">update</span>
</div>
<div>
<h3 class="font-semibold text-slate-900 dark:text-white line-through">Late Checkout - 2 PM</h3>
<p class="text-xs text-slate-500 dark:text-slate-400">Completed at 14:00 • Reception</p>
</div>
</div>
<span class="flex items-center gap-1 text-emerald-600 dark:text-emerald-400 text-[10px] font-bold uppercase tracking-wide">
<span class="material-icons text-xs">check_circle</span>
                            Approved
                        </span>
</div>
</div>
</section>
</main>
<button class="fixed bottom-28 right-6 w-14 h-14 bg-primary text-white rounded-full shadow-lg shadow-primary/40 flex items-center justify-center z-30">
<span class="material-icons text-3xl">add</span>
</button>
<div class="fixed bottom-8 left-1/2 -translate-x-1/2 w-[90%] max-w-[380px] z-50">
<nav class="glass-nav rounded-full h-16 px-2 flex items-center justify-between">
<button class="flex-1 flex flex-col items-center justify-center gap-0.5 text-slate-400 dark:text-slate-500">
<span class="material-symbols-outlined text-[24px]">home</span>
<span class="text-[10px] font-medium">Home</span>
</button>
<button class="flex-1 flex flex-col items-center justify-center gap-0.5 text-slate-400 dark:text-slate-500">
<span class="material-symbols-outlined text-[24px]">grid_view</span>
<span class="text-[10px] font-medium">Services</span>
</button>
<button class="flex-1 flex flex-col items-center justify-center gap-0.5 text-primary">
<span class="material-symbols-outlined text-[24px] font-bold" style="font-variation-settings: 'FILL' 1">receipt_long</span>
<span class="text-[10px] font-bold">Orders</span>
</button>
<button class="flex-1 flex flex-col items-center justify-center gap-0.5 text-slate-400 dark:text-slate-500">
<span class="material-symbols-outlined text-[24px]">person</span>
<span class="text-[10px] font-medium">Profile</span>
</button>
</nav>
</div>
</div>
</body></html>