<!DOCTYPE html>
<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Roomie Guest - Home (Not Logged In)</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#1152d4",
                        "royal-blue": "#0a2472",
                        "background-light": "#f6f6f8",
                        "background-dark": "#101622",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"],
                        "serif": ["Playfair Display", "serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
<style>
        body {
            -webkit-tap-highlight-color: transparent;
            min-height: max(884px, 100dvh);
        }
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 min-h-screen flex justify-center">
<div class="w-full max-w-[430px] bg-background-light dark:bg-background-dark min-h-screen relative overflow-hidden shadow-2xl flex flex-col">
<div class="h-12 w-full flex items-center justify-between px-8 pt-4">
<span class="text-xs font-semibold">9:41</span>
<div class="flex gap-1 items-center">
<span class="material-icons text-xs">signal_cellular_alt</span>
<span class="material-icons text-xs">wifi</span>
<span class="material-icons text-xs">battery_full</span>
</div>
</div>
<header class="px-6 py-4 flex items-center justify-between">
<div>
<p class="text-slate-500 dark:text-slate-400 text-sm font-medium">Experience Luxury</p>
<h1 class="text-2xl font-bold tracking-tight font-serif">Welcome to Roomie</h1>
</div>
<div class="relative">
<div class="w-10 h-10 rounded-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center text-slate-400">
<span class="material-icons">person</span>
</div>
</div>
</header>
<section class="px-6 py-2">
<div class="rounded-2xl relative overflow-hidden h-[360px] shadow-xl group">
<img alt="Soft-focus luxury balcony overlooking serene landscape" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCj1XlAYSybn6II22FXx6AB947ePEGNDvqml25hsYEoic_8KQmwzuncUcV-BSac0_2ysFnIO_AHYWiO_j4R16u5Dt3OlgF81GMwhKnctrEvKc5iQW8FjnM8JimApXzwkIjjtlg0cDrfEeATmoa7ugtilikS0CUkjlNYtafSXB6u2ZEXdsXAI3-5_8_kt4x6uLX6BrPEugFaeMBkaq6jGx9cbL8xfJ3gaaZ6U-EN99k4DqAIbYFPRkdM1VfTYXpTtJTiAFmQXtkvp6x9"/>
<div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/40 to-transparent"></div>
<div class="absolute bottom-0 left-0 w-full p-6 flex flex-col gap-5">
<div class="text-white drop-shadow-md">
<h2 class="text-3xl font-serif font-medium mb-2 leading-tight">Unlock Exclusive Stays</h2>
<p class="text-white/90 text-sm font-light leading-relaxed">Join our community to access premium bookings and personalized services.</p>
</div>
<div class="flex flex-col gap-3">
<button class="w-full bg-white/10 backdrop-blur-md border border-white/20 text-white py-3.5 rounded-xl font-semibold hover:bg-white/20 active:scale-[0.98] transition-all flex items-center justify-center gap-2 shadow-lg">
<span>Login</span>
</button>
<button class="w-full bg-white text-slate-900 py-3.5 rounded-xl font-semibold shadow-lg active:scale-[0.98] transition-all flex items-center justify-center gap-2 hover:bg-slate-50">
<span>Create Account</span>
</button>
</div>
</div>
</div>
</section>
<section class="px-6 py-6 pb-32">
<div class="flex gap-4 items-center">
<div class="flex-1 relative group">
<div class="absolute inset-0 bg-white/60 dark:bg-slate-800/60 backdrop-blur-xl rounded-2xl border border-white/50 dark:border-slate-700/50 shadow-sm transition-all duration-300 group-focus-within:ring-1 group-focus-within:ring-primary/30 group-focus-within:shadow-md"></div>
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-primary/80 font-light text-[22px] z-10">search</span>
<input class="w-full pl-12 pr-28 py-4 bg-transparent border-none rounded-2xl text-base font-display font-medium text-slate-800 dark:text-slate-100 placeholder:text-slate-400 placeholder:font-display focus:ring-0 relative z-10" placeholder="Find your next stay" type="text"/>
<button class="absolute right-2 top-1/2 -translate-y-1/2 bg-white/80 dark:bg-slate-700/80 hover:bg-white dark:hover:bg-slate-600 backdrop-blur-sm px-3 py-1.5 rounded-xl shadow-sm border border-slate-100 dark:border-slate-600 flex items-center gap-1.5 transition-colors z-20">
<span class="material-symbols-outlined text-[16px] text-primary">near_me</span>
<span class="text-[10px] font-semibold text-slate-600 dark:text-slate-300 uppercase tracking-wide">Nearby</span>
</button>
</div>
<button class="w-[52px] h-[52px] bg-slate-100/80 dark:bg-slate-800/80 rounded-full flex items-center justify-center shadow-lg shadow-slate-200/50 dark:shadow-none hover:shadow-xl transition-all border border-slate-100 dark:border-slate-700 flex-shrink-0 group">
<span class="material-symbols-outlined text-[22px] text-primary font-light group-hover:scale-105 transition-transform duration-200" style="font-variation-settings: 'wght' 300;">tune</span>
</button>
</div>
</section>
<nav class="fixed bottom-6 left-1/2 -translate-x-1/2 w-[calc(100%-3rem)] max-w-[380px] bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl border border-white/50 dark:border-slate-700/50 rounded-full px-6 py-4 flex justify-between items-center z-50 shadow-lg shadow-slate-200/40 dark:shadow-slate-900/40">
<a class="flex flex-col items-center gap-1 text-royal-blue hover:text-royal-blue transition-colors relative" href="#">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 24;">home</span>
<span class="sr-only">Home</span>
<span class="absolute -bottom-2 w-1 h-1 bg-royal-blue rounded-full"></span>
</a>
<a class="flex flex-col items-center gap-1 text-slate-400 hover:text-royal-blue dark:hover:text-white transition-colors" href="#">
<span class="material-icons">calendar_month</span>
<span class="sr-only">Bookings</span>
</a>
<a class="flex flex-col items-center gap-1 text-slate-400 hover:text-royal-blue dark:hover:text-white transition-colors" href="#">
<span class="material-icons">support_agent</span>
<span class="sr-only">Services</span>
</a>
<a class="flex flex-col items-center gap-1 text-slate-400 hover:text-royal-blue dark:hover:text-white transition-colors" href="#">
<span class="material-icons">person_outline</span>
<span class="sr-only">Profile</span>
</a>
</nav>
<div class="fixed bottom-1 left-1/2 -translate-x-1/2 w-32 h-1 bg-slate-200 dark:bg-slate-800 rounded-full z-40"></div>
</div>
</body></html>