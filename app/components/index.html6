<!DOCTYPE html>
<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Roomie Guest - Home</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#1152d4",
                        "background-light": "#f6f6f8",
                        "background-dark": "#101622",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"],
                        "serif": ["Playfair Display", "serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
<style type="text/tailwindcss">
        body {
            -webkit-tap-highlight-color: transparent;
            min-height: max(884px, 100dvh);
        }
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        .glass-nav {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }
        .dark .glass-nav {
            background: rgba(15, 23, 42, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.4);
        }
        .dark .glass-card {
            background: rgba(30, 41, 59, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .glass-panel {
            background: rgba(255, 255, 255, 0.45);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.05);
        }
        .dark .glass-panel {
            background: rgba(30, 41, 59, 0.45);
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 min-h-screen flex justify-center">
<div class="w-full max-w-[430px] bg-background-light dark:bg-background-dark min-h-screen relative overflow-hidden shadow-2xl flex flex-col">
<div class="h-12 w-full flex items-center justify-between px-8 pt-4">
<span class="text-xs font-semibold">9:41</span>
<div class="flex gap-1 items-center">
<span class="material-icons text-xs">signal_cellular_alt</span>
<span class="material-icons text-xs">wifi</span>
<span class="material-icons text-xs">battery_full</span>
</div>
</div>
<header class="px-6 py-4 flex items-center justify-between">
<div>
<p class="text-slate-500 dark:text-slate-400 text-sm font-medium">Welcome back,</p>
<h1 class="text-2xl font-bold tracking-tight">Good Morning, Alex</h1>
</div>
<div class="relative">
<img alt="Profile avatar" class="w-12 h-12 rounded-full border-2 border-white shadow-sm object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBsXP4Fq3FOAPvvFpSLiNocwn8iHndukT3Eu6h3FgdZPsNJGprZkFhdID5Uyx-ptOTp8_A9Vyx-0DJynCg0OmEdhNz63i7qsjdVyqSh8IF-yMP8vuXFCy4xbCt45cEL83GwOPnl0mtiY95Mh5blIVf0-noecPxJ8MNM9rpB0KOx4wD5s8HyxoKwkaXAf41_BCLBGwM5HWyCwi-I2641IsLJiJxJ51ZgDO2Qe3ES_5QYk8EwoqUae0X1KBNQjN1UYGL4bb-4zy9dUDyj"/>
<span class="absolute bottom-0 right-0 w-3 h-3 bg-green-500 border-2 border-white rounded-full"></span>
</div>
</header>
<section class="px-6 py-4">
<div class="bg-primary rounded-xl p-6 text-white shadow-xl shadow-primary/20 relative overflow-hidden">
<div class="absolute -right-8 -top-8 w-32 h-32 bg-white/10 rounded-full blur-2xl"></div>
<div class="absolute -left-4 -bottom-4 w-24 h-24 bg-white/5 rounded-full blur-xl"></div>
<div class="relative z-10 text-center">
<div class="mb-6">
<span class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-80">Current Stay</span>
<h2 class="text-2xl font-bold mt-1.5 leading-tight">Grand Hyatt Regency</h2>
</div>
<div class="flex items-center justify-around mb-8 px-4">
<div class="flex flex-col items-center">
<p class="text-[10px] uppercase tracking-wider opacity-70 mb-1">Room</p>
<p class="text-3xl font-bold leading-none">402</p>
</div>
<div class="h-8 w-px bg-white/20"></div>
<div class="flex flex-col items-center">
<p class="text-[10px] uppercase tracking-wider opacity-70 mb-1">Check-out</p>
<div class="flex items-center gap-1.5">
<span class="material-icons text-[14px] opacity-70">calendar_today</span>
<p class="text-sm font-semibold">Oct 12 - Oct 15</p>
</div>
</div>
</div>
<div class="w-full max-w-[280px] mx-auto">
<div class="w-full bg-white/20 h-1.5 rounded-full overflow-hidden">
<div class="bg-white h-full w-2/3 rounded-full"></div>
</div>
<p class="text-[11px] mt-3 font-medium opacity-90">2 days remaining in your stay</p>
</div>
</div>
</div>
</section>
<section class="px-6 py-4">
<div class="flex gap-4 items-center">
<div class="flex-1 relative group">
<div class="absolute inset-0 bg-white/60 dark:bg-slate-800/60 backdrop-blur-xl rounded-2xl border border-white/50 dark:border-slate-700/50 shadow-sm transition-all duration-300 group-focus-within:ring-1 group-focus-within:ring-primary/30 group-focus-within:shadow-md"></div>
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-primary/80 font-light text-[22px] z-10">search</span>
<input class="w-full pl-12 pr-28 py-4 bg-transparent border-none rounded-2xl text-base font-display font-medium text-slate-800 dark:text-slate-100 placeholder:text-slate-400 placeholder:font-display focus:ring-0 relative z-10" placeholder="Find your next stay" type="text"/>
<button class="absolute right-2 top-1/2 -translate-y-1/2 bg-white/80 dark:bg-slate-700/80 hover:bg-white dark:hover:bg-slate-600 backdrop-blur-sm px-3 py-1.5 rounded-xl shadow-sm border border-slate-100 dark:border-slate-600 flex items-center gap-1.5 transition-colors z-20">
<span class="material-symbols-outlined text-[16px] text-primary">near_me</span>
<span class="text-[10px] font-semibold text-slate-600 dark:text-slate-300 uppercase tracking-wide">Nearby</span>
</button>
</div>
<button class="w-[52px] h-[52px] bg-slate-100/80 dark:bg-slate-800/80 rounded-full flex items-center justify-center shadow-lg shadow-slate-200/50 dark:shadow-none hover:shadow-xl transition-all border border-slate-100 dark:border-slate-700 flex-shrink-0 group">
<span class="material-symbols-outlined text-[22px] text-primary font-light group-hover:scale-105 transition-transform duration-200" style="font-variation-settings: 'wght' 300;">tune</span>
</button>
</div>
</section>
<section class="py-4">
<div class="px-6 flex items-center justify-between mb-4">
<h3 class="text-lg font-bold">Recommended for you</h3>
<button class="text-primary text-xs font-semibold">See all</button>
</div>
<div class="flex overflow-x-auto hide-scrollbar gap-4 px-6 pb-4">
<div class="flex-shrink-0 w-64 bg-white dark:bg-slate-800 rounded-xl overflow-hidden shadow-sm border border-slate-100 dark:border-slate-700">
<div class="relative h-44">
<img alt="Luxury resort" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDXmyoLaf9HHG60bVVCaxqUHNw_ryNKhRgHYK2abgkHT4dZlcemXz9aKS72YHMnMqudN4VLqTJxelCWCfO2OCv1FPJNnzyuRRvEieQxmtf0EofO2jsm6WGVaxJFhyvIaCdyIBkvfPIyfcDt7H0YId4thkQPrvWUOmPxYU-Grt878dXSJ6jwrs4J9PZzo5oT17FaN2SAnSvqEGCAr1JIC8ugB3UgPvveAh-aR4yiPnSN7mm904Gmnhsb8zj4FknPTjHT2_7sw_MfCbGe"/>
<button class="absolute top-3 right-3 bg-white/30 backdrop-blur-md p-1.5 rounded-full text-white">
<span class="material-icons text-sm">favorite_border</span>
</button>
<div class="absolute bottom-3 left-3 bg-primary text-[10px] text-white font-bold px-2 py-1 rounded">
                        FEATURED
                    </div>
</div>
<div class="p-4">
<div class="flex justify-between items-start mb-1">
<h4 class="font-bold text-sm truncate">The Ritz-Carlton</h4>
<div class="flex items-center text-xs font-bold text-amber-500">
<span class="material-icons text-xs mr-0.5">star</span>
                            4.9
                        </div>
</div>
<p class="text-slate-500 dark:text-slate-400 text-xs mb-3 flex items-center">
<span class="material-icons text-xs mr-1">location_on</span>
                        Malibu, California
                    </p>
<div class="flex items-center justify-between">
<p class="text-sm font-bold text-primary">$450<span class="text-[10px] text-slate-400 font-normal"> /night</span></p>
<span class="material-icons text-slate-300 text-sm">arrow_forward</span>
</div>
</div>
</div>
<div class="flex-shrink-0 w-64 bg-white dark:bg-slate-800 rounded-xl overflow-hidden shadow-sm border border-slate-100 dark:border-slate-700">
<div class="relative h-44">
<img alt="Modern villa" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBx3yKZ4MbwFzhmVbQNgriFOFIIIHGdTcYocFeypzPizPyEW9IWRkHP16_e7CYhM9L8tTgsPCFDjqiybAkVB8SICXRm_6FUFPXjMN2huIMtdbdI3DGXAwGp9YZj2XhFmqN19bTeOs4uSUVwP7cBz2nEXSUS03W48FAKDWPTr9PxvpHKQ_wqgCPXkYKJbjVvIiQqQqOGFS33bqId3uw7q3eXEYfpB2E92LGCyOPaPc7viuniBuQzBhnnUqEyMIdmWKu4ReC3mh_dr-4g"/>
<button class="absolute top-3 right-3 bg-white/30 backdrop-blur-md p-1.5 rounded-full text-white">
<span class="material-icons text-sm">favorite_border</span>
</button>
</div>
<div class="p-4">
<div class="flex justify-between items-start mb-1">
<h4 class="font-bold text-sm truncate">Amangiri Resort</h4>
<div class="flex items-center text-xs font-bold text-amber-500">
<span class="material-icons text-xs mr-0.5">star</span>
                            4.8
                        </div>
</div>
<p class="text-slate-500 dark:text-slate-400 text-xs mb-3 flex items-center">
<span class="material-icons text-xs mr-1">location_on</span>
                        Canyon Point, Utah
                    </p>
<div class="flex items-center justify-between">
<p class="text-sm font-bold text-primary">$820<span class="text-[10px] text-slate-400 font-normal"> /night</span></p>
<span class="material-icons text-slate-300 text-sm">arrow_forward</span>
</div>
</div>
</div>
</div>
</section>
<section class="px-6 py-4 mb-4">
<h3 class="text-lg font-bold mb-4">Guest Services</h3>
<div class="flex justify-between items-start gap-4">
<div class="flex flex-col items-center gap-2 flex-1">
<div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center text-primary shadow-sm">
<span class="material-icons text-[28px]">room_service</span>
</div>
<span class="text-[11px] font-semibold text-slate-600 dark:text-slate-400">Dining</span>
</div>
<div class="flex flex-col items-center gap-2 flex-1">
<div class="w-16 h-16 rounded-2xl bg-indigo-50 dark:bg-indigo-900/30 flex items-center justify-center text-indigo-600 dark:text-indigo-400 shadow-sm">
<span class="material-icons text-[28px]">cleaning_services</span>
</div>
<span class="text-[11px] font-semibold text-slate-600 dark:text-slate-400">Cleaning</span>
</div>
<div class="flex flex-col items-center gap-2 flex-1">
<div class="w-16 h-16 rounded-2xl bg-teal-50 dark:bg-teal-900/30 flex items-center justify-center text-teal-600 dark:text-teal-400 shadow-sm">
<span class="material-icons text-[28px]">spa</span>
</div>
<span class="text-[11px] font-semibold text-slate-600 dark:text-slate-400">Spa</span>
</div>
</div>
</section>
<section class="px-6 pb-32 mt-4">
<div class="glass-panel rounded-3xl p-6 relative overflow-hidden">
<div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-blue-400/10 to-transparent rounded-full blur-2xl -translate-y-1/2 translate-x-1/2"></div>
<div class="absolute bottom-0 left-0 w-24 h-24 bg-gradient-to-tr from-purple-400/10 to-transparent rounded-full blur-2xl translate-y-1/2 -translate-x-1/2"></div>
<div class="relative z-10 flex flex-col items-center">
<div class="mb-5 text-center w-full">
<h4 class="text-sm font-semibold text-slate-700 dark:text-slate-200">
                        Quick Contact
                    </h4>
</div>
<div class="flex justify-between items-center w-full px-2 gap-3">
<button class="flex flex-col items-center gap-2 group flex-1">
<div class="w-12 h-12 rounded-2xl bg-white/70 dark:bg-slate-700/70 backdrop-blur-sm flex items-center justify-center text-slate-500 dark:text-slate-400 group-hover:bg-slate-100 dark:group-hover:bg-slate-600 transition-all duration-300 shadow-sm border border-white/50 dark:border-slate-600">
<i class="fa-brands fa-telegram text-2xl"></i>
</div>
<span class="text-[11px] font-medium text-slate-600 dark:text-slate-300">Telegram</span>
</button>
<button class="flex flex-col items-center gap-2 group flex-1">
<div class="w-12 h-12 rounded-2xl bg-white/70 dark:bg-slate-700/70 backdrop-blur-sm flex items-center justify-center text-slate-500 dark:text-slate-400 group-hover:bg-slate-100 dark:group-hover:bg-slate-600 transition-all duration-300 shadow-sm border border-white/50 dark:border-slate-600">
<i class="fa-brands fa-whatsapp text-2xl"></i>
</div>
<span class="text-[11px] font-medium text-slate-600 dark:text-slate-300">WhatsApp</span>
</button>
<button class="flex flex-col items-center gap-2 group flex-1">
<div class="w-12 h-12 rounded-2xl bg-white/70 dark:bg-slate-700/70 backdrop-blur-sm flex items-center justify-center text-slate-500 dark:text-slate-400 group-hover:bg-slate-100 dark:group-hover:bg-slate-600 transition-all duration-300 shadow-sm border border-white/50 dark:border-slate-600">
<span class="material-icons text-[24px]">call</span>
</div>
<span class="text-[11px] font-medium text-slate-600 dark:text-slate-300">Call Us</span>
</button>
</div>
</div>
</div>
</section>
<div class="fixed bottom-6 left-1/2 -translate-x-1/2 w-[calc(100%-48px)] max-w-[380px] z-[60]">
<nav class="glass-nav rounded-full border border-white/20 dark:border-slate-700/50 shadow-[0_8px_32px_0_rgba(0,0,0,0.15)] flex justify-between items-center px-6 py-3.5">
<a class="flex flex-col items-center gap-1 text-primary transition-all duration-300" href="#">
<span class="material-symbols-outlined text-[24px]">home</span>
<span class="text-[10px] font-bold">Home</span>
</a>
<a class="flex flex-col items-center gap-1 text-slate-400 dark:text-slate-500 hover:text-primary transition-all duration-300" href="#">
<span class="material-icons text-[24px]">support_agent</span>
<span class="text-[10px] font-medium">Services</span>
</a>
<a class="flex flex-col items-center gap-1 text-slate-400 dark:text-slate-500 hover:text-primary transition-all duration-300" href="#">
<span class="material-symbols-outlined text-[24px]">shopping_bag</span>
<span class="text-[10px] font-medium">Orders</span>
</a>
<a class="flex flex-col items-center gap-1 text-slate-400 dark:text-slate-500 hover:text-primary transition-all duration-300" href="#">
<span class="material-icons text-[24px]">person_outline</span>
<span class="text-[10px] font-medium">Profile</span>
</a>
</nav>
</div>
<div class="fixed bottom-1.5 left-1/2 -translate-x-1/2 w-32 h-1 bg-slate-200/50 dark:bg-slate-800/50 rounded-full z-[70]"></div>
</div>

</body></html>