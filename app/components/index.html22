<!DOCTYPE html>

<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Roomie Guest - My Cart</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script>
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "primary": "#1052d5",
              "background-light": "#f6f6f8",
              "background-dark": "#101622",
            },
            fontFamily: {
              "display": ["Plus Jakarta Sans", "sans-serif"]
            },
            borderRadius: {
                "DEFAULT": "1rem", 
                "lg": "2rem", 
                "xl": "3rem", 
                "full": "9999px"
            },
          },
        },
      }
    </script>
<style>
        body {
            font-family: "Plus Jakarta Sans", sans-serif;
            -webkit-font-smoothing: antialiased;
        }
        /* Hide scrollbar for Chrome, Safari and Opera */
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        /* Hide scrollbar for IE, Edge and Firefox */
        .no-scrollbar {
            -ms-overflow-style: none;  /* IE and Edge */
            scrollbar-width: none;  /* Firefox */
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background-light text-slate-900 dark:bg-background-dark dark:text-slate-100 min-h-screen flex flex-col items-center justify-center">
<!-- Mobile Device Frame Wrapper (Optional for visual context, usually implied) -->
<div class="w-full max-w-md bg-background-light dark:bg-background-dark min-h-screen flex flex-col relative shadow-2xl overflow-hidden mx-auto">
<!-- Header -->
<header class="flex items-center justify-between px-6 pt-12 pb-4 bg-background-light dark:bg-background-dark sticky top-0 z-20">
<button class="flex items-center justify-center w-10 h-10 rounded-full bg-white dark:bg-slate-800 shadow-sm text-slate-800 dark:text-white hover:bg-slate-50 transition-colors">
<span class="material-symbols-outlined text-[20px]">arrow_back</span>
</button>
<h1 class="text-lg font-bold text-slate-900 dark:text-white tracking-tight">My Cart</h1>
<div class="w-10"></div> <!-- Spacer to center title -->
</header>
<!-- Scrollable Content -->
<main class="flex-1 overflow-y-auto no-scrollbar pb-32 px-6">
<!-- Cart Items -->
<div class="space-y-6 mt-4">
<!-- Item 1 -->
<div class="flex items-start gap-4 p-4 bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700">
<div class="w-20 h-20 shrink-0 rounded-xl bg-cover bg-center relative overflow-hidden" data-alt="Gourmet truffle burger on wooden plate" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDRh8NpCBnZlcxrkoYfE6ZzgDfp7a_XZFNuhtvaL1y8HuJvwMkdpR6P6e1lFOXd0FwOqEdJkaabqtz2RVx3yFcXuv2yJ-gHPuVk7yx5WHg-6hJfo94yUcZYlUN3bZVVNVrCa5noQlxfb4yibm0NnzUJmexQX3c2XlXf1w6isIEHBExmDo2Y-RzIXo4WEAUgS1wKGmmVQtzySdNDhfwHev_H4_Fpy3HriHMk7k_CRDF-rYFZgIJRNcmopfob58gf1KFcRmNPEDbCapdC');">
<div class="absolute inset-0 bg-black/5"></div>
</div>
<div class="flex-1 flex flex-col h-full justify-between min-h-[5rem]">
<div>
<h3 class="text-slate-900 dark:text-white font-semibold text-base leading-tight mb-1">Truffle Wagyu Burger</h3>
<p class="text-primary font-medium text-sm">$42.00</p>
</div>
<div class="flex items-center justify-between mt-3">
<div class="flex items-center bg-slate-50 dark:bg-slate-700 rounded-full px-1 py-1 gap-3">
<button class="w-7 h-7 flex items-center justify-center rounded-full bg-white dark:bg-slate-600 shadow-sm text-slate-600 dark:text-slate-200 hover:text-primary transition-colors">
<span class="material-symbols-outlined text-[16px]">remove</span>
</button>
<span class="text-sm font-semibold text-slate-900 dark:text-white w-4 text-center">1</span>
<button class="w-7 h-7 flex items-center justify-center rounded-full bg-primary text-white shadow-sm hover:bg-primary/90 transition-colors">
<span class="material-symbols-outlined text-[16px]">add</span>
</button>
</div>
<button class="text-slate-400 hover:text-red-500 transition-colors">
<span class="material-symbols-outlined text-[20px]">delete</span>
</button>
</div>
</div>
</div>
<!-- Item 2 -->
<div class="flex items-start gap-4 p-4 bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700">
<div class="w-20 h-20 shrink-0 rounded-xl bg-cover bg-center relative overflow-hidden" data-alt="Fresh orange juice in glass with mint" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBUxW6Veq0jYGP1AB0TrHzq_t_9stm9DfSY1PNxU21wnt--RuYCv0bLoxcSpN0A3L-GUta6ywf-FAs_KdHsoJTLXgHELdOvKwEN3QOi-Ab9P7HTH8SOWTzbWylBjkh4tM-ZtFL4uKNxfJX1x-beeG9Ch8AQbzc3bQXTIVV4ochOPVzcsBkd41qtdpCJH5I5ZuV6eI379dMMyKAJC9webhgepZuy5vziDaPlNyeFuT8yqHEfPFRWTLooRseqJ7VSpgOxIkfD5nIVX7Wy');">
<div class="absolute inset-0 bg-black/5"></div>
</div>
<div class="flex-1 flex flex-col h-full justify-between min-h-[5rem]">
<div>
<h3 class="text-slate-900 dark:text-white font-semibold text-base leading-tight mb-1">Fresh Orange Juice</h3>
<p class="text-primary font-medium text-sm">$12.00</p>
</div>
<div class="flex items-center justify-between mt-3">
<div class="flex items-center bg-slate-50 dark:bg-slate-700 rounded-full px-1 py-1 gap-3">
<button class="w-7 h-7 flex items-center justify-center rounded-full bg-white dark:bg-slate-600 shadow-sm text-slate-600 dark:text-slate-200 hover:text-primary transition-colors">
<span class="material-symbols-outlined text-[16px]">remove</span>
</button>
<span class="text-sm font-semibold text-slate-900 dark:text-white w-4 text-center">2</span>
<button class="w-7 h-7 flex items-center justify-center rounded-full bg-primary text-white shadow-sm hover:bg-primary/90 transition-colors">
<span class="material-symbols-outlined text-[16px]">add</span>
</button>
</div>
<button class="text-slate-400 hover:text-red-500 transition-colors">
<span class="material-symbols-outlined text-[20px]">delete</span>
</button>
</div>
</div>
</div>
</div>
<!-- Special Instructions -->
<div class="mt-8">
<h3 class="text-slate-900 dark:text-white text-base font-bold mb-3 flex items-center gap-2">
<span class="material-symbols-outlined text-primary text-[20px]">edit_note</span>
                    Special Instructions
                </h3>
<div class="relative">
<textarea class="w-full bg-white dark:bg-slate-800 border-none rounded-2xl p-4 text-sm text-slate-700 dark:text-slate-300 placeholder-slate-400 focus:ring-2 focus:ring-primary shadow-sm min-h-[100px] resize-none" placeholder="Any allergies or special requests? (e.g. No onions)"></textarea>
</div>
</div>
<!-- Order Summary -->
<div class="mt-8 mb-6">
<h3 class="text-slate-900 dark:text-white text-base font-bold mb-4">Order Summary</h3>
<div class="bg-white dark:bg-slate-800 rounded-2xl p-5 shadow-sm space-y-3">
<div class="flex justify-between items-center text-sm">
<span class="text-slate-500 dark:text-slate-400">Subtotal</span>
<span class="font-semibold text-slate-900 dark:text-white">$66.00</span>
</div>
<div class="flex justify-between items-center text-sm">
<span class="text-slate-500 dark:text-slate-400">Service Fee (10%)</span>
<span class="font-semibold text-slate-900 dark:text-white">$6.60</span>
</div>
<div class="flex justify-between items-center text-sm">
<span class="text-slate-500 dark:text-slate-400">Room Service Charge</span>
<span class="font-semibold text-slate-900 dark:text-white">$5.00</span>
</div>
<div class="h-px bg-slate-100 dark:bg-slate-700 my-2"></div>
<div class="flex justify-between items-center">
<span class="text-base font-bold text-slate-900 dark:text-white">Total</span>
<span class="text-xl font-bold text-primary">$77.60</span>
</div>
</div>
</div>
<!-- Place Order Button Area -->
<div class="mt-4 pb-4">
<button class="w-full bg-primary hover:bg-blue-700 text-white font-bold py-4 rounded-full shadow-lg shadow-blue-500/30 active:scale-[0.98] transition-all flex items-center justify-center gap-2 text-base">
<span>Place Order</span>
<span class="material-symbols-outlined text-[20px]">arrow_forward</span>
</button>
<p class="text-center text-xs text-slate-400 mt-3">Prices include all applicable taxes</p>
</div>
</main>
<!-- Floating Bottom Navigation -->
<div class="absolute bottom-6 left-0 right-0 px-6 z-30">
<div class="bg-white dark:bg-slate-900 rounded-full shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-slate-100 dark:border-slate-800 h-[72px] flex items-center justify-around px-2 backdrop-blur-md bg-white/90 dark:bg-slate-900/90">
<a class="flex flex-col items-center justify-center w-16 h-full gap-1 group" href="#">
<span class="material-symbols-outlined text-slate-400 group-hover:text-primary transition-colors text-[24px]">home</span>
<span class="text-[10px] font-medium text-slate-400 group-hover:text-primary transition-colors">Home</span>
</a>
<a class="flex flex-col items-center justify-center w-16 h-full gap-1 group" href="#">
<span class="material-symbols-outlined text-slate-400 group-hover:text-primary transition-colors text-[24px]">room_service</span>
<span class="text-[10px] font-medium text-slate-400 group-hover:text-primary transition-colors">Services</span>
</a>
<a class="flex flex-col items-center justify-center w-16 h-full gap-1 relative" href="#">
<div class="absolute top-2 right-4 w-2 h-2 bg-red-500 rounded-full"></div>
<div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mb-1">
<span class="material-symbols-outlined text-primary fill-current text-[24px]">receipt_long</span>
</div>
</a>
<a class="flex flex-col items-center justify-center w-16 h-full gap-1 group" href="#">
<span class="material-symbols-outlined text-slate-400 group-hover:text-primary transition-colors text-[24px]">person</span>
<span class="text-[10px] font-medium text-slate-400 group-hover:text-primary transition-colors">Profile</span>
</a>
</div>
</div>
</div>
</body></html>