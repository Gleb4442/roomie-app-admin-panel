NODE_ENV=production
PORT=3001

# Database
DATABASE_URL=postgresql://hotelmol:${DB_PASSWORD}@postgres:5432/hotelmol
DB_PASSWORD=generate_strong_password_here

# Redis
REDIS_URL=redis://redis:6379

# JWT Secrets — generate with: openssl rand -base64 64
JWT_SECRET=generate_random_64_chars
JWT_REFRESH_SECRET=generate_random_64_chars
HOTELMOL_ADMIN_JWT_SECRET=generate_random_64_chars
DASHBOARD_MANAGER_JWT_SECRET=generate_random_64_chars
STAFF_JWT_SECRET=generate_random_64_chars

# Admin credentials
HOTELMOL_ADMIN_USERNAME=admin
HOTELMOL_ADMIN_PASSWORD=generate_strong_password_here

# App
APP_BASE_URL=https://app.hotelmol.com
ROOMIE_API_URL=https://roomie-api.hotelmol.com

# SMS (optional — leave empty to use LogAdapter in dev)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
